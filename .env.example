# Shared local credentials for every character project in this workspace.
# Copy this file to the workspace root as .env and never commit the real file.
# A character pipeline may override this path with CODEX_PET_ENV_FILE when needed.
IMAGE_API_KEY=replace-with-your-api-key
IMAGE_API_BASE=https://your-openai-compatible-endpoint.example/v1
IMAGE_MODEL=gpt-image-2-0421-global
