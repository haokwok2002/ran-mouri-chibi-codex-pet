# Workspace-level local environment files and secrets — never commit
.env
.env.*
!.env.example

# Python virtual environments and bytecode
.venv/
venv/
__pycache__/
*.py[cod]

# Editor and operating-system metadata
.DS_Store
.idea/
.vscode/

# Pipeline intermediates regenerated by each character build
/pets/*/production-pipeline/source/sequences/matted/*
!/pets/*/production-pipeline/source/sequences/matted/.gitkeep

